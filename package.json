{
  "name": "@wyrd-company/ahp-cursor-sdk",
  "version": "0.3.1",
  "description": "Agent Host Protocol provider adapter for Cursor SDK.",
  "type": "module",
  "license": "MIT",
  "author": "Wyrd Company",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wyrd-company/ahp-cursor-sdk.git"
  },
  "files": [
    "dist/src",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "prepack": "npm run clean && npm run build",
    "prepublishOnly": "npm run verify",
    "test": "node --test --import tsx test/*.test.ts",
    "test:live": "scripts/validate-live-cursor-sdk.sh",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "verify": "npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "@cursor/sdk": "^1.0.18",
    "@microsoft/agent-host-protocol": "^0.3.0",
    "@wyrd-company/ahp-provider-kit": "^0.3.0"
  },
  "peerDependencies": {
    "@wyrd-company/ahp-server": "^0.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@wyrd-company/ahp-server": "^0.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
